# -----------------------------------------------------------------
# Core Engine Environment Variables
# -----------------------------------------------------------------

# Local Supabase Postgres connection string
DATABASE_URL=postgresql://postgres:Kurade@%40890.txt@db.regynxxiqwkmbycofxyt.supabase.co:5432/postgres

# How often the Go engine checks the DB for new 'pending' jobs (ms)
POLL_INTERVAL_MS=1000

# -----------------------------------------------------------------
# API Keys (Leave blank for Mock Mode)
# -----------------------------------------------------------------

# OpenAI (Required if your BOM contains descriptive/human-written part names)
# If blank, the engine will fail on ambiguous parts, but will still process exact part numbers.
OPENAI_API_KEY=

# DigiKey (Leave blank to use internal Mock Data)
DIGIKEY_CLIENT_ID=
DIGIKEY_CLIENT_SECRET=

# Mouser (Leave blank to use internal Mock Data)
MOUSER_SEARCH_API_KEY=d8f58ca6-fdb3-45c9-a275-79d88e8e2ad2
